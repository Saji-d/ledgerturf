# Local dev: Vite proxies /api to the backend (see vite.config.js)
# Production (Vercel): set in ledgerturf-frontend → Settings → Environment Variables
# Must be the full backend URL; /api is appended automatically if omitted.
VITE_API_URL=https://your-backend-project.vercel.app/api

# Optional: Google Maps (turf maps / location picker)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
