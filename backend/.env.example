PORT=5002
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/ledgerturf?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_here
NODE_ENV=development
# Optional: exact frontend URL for CORS (Vercel preview URLs ending in .vercel.app are allowed automatically)
FRONTEND_URL=https://your-frontend-project.vercel.app
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
